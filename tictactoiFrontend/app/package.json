{
  "name": "nuxt-app",
  "type": "module",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "prepare": "npx simple-git-hooks",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . && stylelint '**/*.css'",
    "lint:fix": "eslint . --fix && stylelint '**/*.css' --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@nuxt/content": "^2.13.2",
    "@nuxt/image": "^1.7.1",
    "@nuxt/ui": "^3.3.0",
    "@pinia/nuxt": "^0.5.4",
    "@vueuse/core": "^11.0.3",
    "bootstrap": "^5.2.3",
    "bootstrap-icons": "^1.13.1",
    "lottie-web": "^5.12.0",
    "nuxt": "^3.13.0",
    "nuxt-toastify": "^1.1.0",
    "socket.io-client": "^4.7.2",
    "uuid": "^9.0.1",
    "vue": "latest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.0.0",
    "@nuxt/test-utils": "^3.14.1",
    "@types/canvas-confetti": "^1.9.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.9.1",
    "happy-dom": "^14.12.3",
    "nuxt3-notifications": "^1.3.1",
    "simple-git-hooks": "^2.11.1",
    "stylelint": "^16.9.0",
    "stylelint-config-standard": "^36.0.1",
    "vitest": "^2.0.5"
  },
  "overrides": {
    "vue": "latest"
  },
  "simple-git-hooks": {
    "pre-commit": "cd app && npm run lint:fix"
  }
}
